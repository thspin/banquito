# ============================================================================
# Banquito Production Environment Variables
# ============================================================================
# 
# IMPORTANTE: Estos valores deben estar configurados en Vercel, NO en este 
# archivo. Este archivo es solo para referencia.
#
# Ver: Vercel Dashboard → Settings → Environment Variables
#

# ==============================================================================
# DATABASE CONFIGURATION (REQUERIDO)
# ==============================================================================
DATABASE_URL=postgresql://user:password@neon-pool.c-4.us-east-1.aws.neon.tech/db?sslmode=require

# ==============================================================================
# TELEGRAM BOT CONFIGURATION (PARA BOT 24/7)
# ==============================================================================
# Token del bot creado en @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ-1234567890

# URL del webhook (debe ser tu dominio Vercel + /api/telegram/webhook)
TELEGRAM_WEBHOOK_URL=https://banquito.vercel.app/api/telegram/webhook

# Secreto para validar que los updates vienen de Telegram (usa openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=abc123def456ghi789jkl012mno345pqr678stu901vwx234yz567abc890def123

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
FRONTEND_URL=https://banquito.vercel.app

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
# Ambiente de ejecución
APP_ENV=production

# Debug mode (SIEMPRE false en producción)
DEBUG=false

# ==============================================================================
# OPCIONAL: CLERK AUTHENTICATION
# ==============================================================================
# Para implementación futura de autenticación Clerk
CLERK_ISSUER=https://xxx.clerk.accounts.dev
CLERK_JWKS_URL=https://xxx.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=https://banquito.vercel.app
CLERK_PEM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...

# ==============================================================================
# CHECKLIST DE VERIFICACIÓN
# ==============================================================================
# 
# Antes de hacer deployment, verifica que:
# 
# ✅ DATABASE_URL apunta a tu base de datos Neon
# ✅ TELEGRAM_BOT_TOKEN es válido (obtenido de @BotFather)
# ✅ TELEGRAM_WEBHOOK_URL es tu dominio + /api/telegram/webhook
# ✅ TELEGRAM_WEBHOOK_SECRET es un string aleatorio largo (32 chars mínimo)
# ✅ FRONTEND_URL es tu dominio en Vercel
# ✅ APP_ENV = production
# ✅ DEBUG = false (nunca true en producción)
#
# Después de configurar en Vercel:
#
# ✅ Hacer git push origin main
# ✅ Esperar a que Vercel termine el deploy
# ✅ Registrar webhook: curl -X POST https://api.telegram.org/bot{TOKEN}/setWebhook ...
# ✅ Probar: curl https://tu-app.vercel.app/api/health
# ✅ Probar bot en Telegram enviando /start
#
