# Banquito Environment Variables Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# DATABASE CONFIGURATION (REQUIRED for production)
# ==============================================================================
# Get this from: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxx-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# ==============================================================================
# TELEGRAM BOT CONFIGURATION
# ==============================================================================
# Get token from: @BotFather in Telegram -> /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOpqrsTUVwxyzABC123456789

# Your Vercel deployment URL with webhook endpoint
# Format: https://your-app.vercel.app/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://banquito.vercel.app/api/telegram/webhook

# Secret token for webhook validation (should be random and long)
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=8f3k9x2c7m1p5q6r9s2t4u7v8w9x0y1z2a3b4c5d6e7f8g9h0i1j2k3l4m5n6

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
# Your frontend URL (for CORS)
FRONTEND_URL=https://banquito.vercel.app

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
# Environment: development or production
APP_ENV=production

# Debug mode (set to false in production)
DEBUG=false

# ==============================================================================
# CLERK AUTHENTICATION (Optional, for future implementation)
# ==============================================================================
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_PEM_PUBLIC_KEY=

# ==============================================================================
# NOTES FOR LOCAL DEVELOPMENT
# ==============================================================================
# 1. For local development, you can use a local PostgreSQL:
#    DATABASE_URL=postgresql://localhost/banquito_dev
#
# 2. For local Telegram bot testing, use polling mode (no webhook):
#    - Leave TELEGRAM_WEBHOOK_URL empty
#    - The bot will use polling instead
#    - APP_ENV=development enables polling
#
# 3. Create a test bot on Telegram for development
#    - Use @BotFather to create a new test bot
#    - Use a different token for dev vs production
